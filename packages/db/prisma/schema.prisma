// DukaPOS — Prisma Schema v1.0
// Generated from PRD v1.0 — April 2026

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  OWNER
  MANAGER
  CASHIER
  STOCK_CLERK
  VIEWER
}

enum PlanTier {
  FREE
  STARTER
  GROWTH
  PRO
}

enum OrderStatus {
  OPEN
  PENDING
  COMPLETED
  VOIDED
  REFUNDED
}

enum PaymentMethod {
  CASH
  MPESA
  CARD
  OTHER
}

enum AdjustmentReason {
  DAMAGE
  RECOUNT
  THEFT
  OPENING_BALANCE
  SALE
  RECEIVE_STOCK
  REFUND
  OTHER
}

enum NotificationType {
  LOW_STOCK
  NEW_SALE
  SYNC_ACK
  SYSTEM
}

// ─────────────────────────────────────────────────────────────────────────────
// BUSINESS (TENANT ROOT)
// ─────────────────────────────────────────────────────────────────────────────

model Business {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  email        String   @unique
  phone        String?
  address      String?
  taxNumber    String?
  logoUrl      String?
  country      String   @default("KE")
  currency     String   @default("KES")
  locale       String   @default("en-KE")
  category     String?
  planTier     PlanTier @default(FREE)
  planExpiresAt DateTime?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  users        User[]
  categories   Category[]
  products     Product[]
  orders       Order[]
  suppliers    Supplier[]
  stockReceipts StockReceipt[]
  notifications Notification[]
  settings     BusinessSettings?

  @@index([slug])
}

// ─────────────────────────────────────────────────────────────────────────────
// AUTH & USERS
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  businessId   String
  email        String
  passwordHash String
  name         String
  phone        String?
  role         Role     @default(CASHIER)
  pin          String?  // bcrypt-hashed 4-6 digit PIN for quick POS login
  isActive     Boolean  @default(true)
  emailVerified Boolean @default(false)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  business     Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]
  orders       Order[]        @relation("CashierOrders")
  adjustments  InventoryAdjustment[]
  activityLogs ActivityLog[]

  @@unique([businessId, email])
  @@index([businessId])
  @@index([email])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?
  deviceInfo String?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model EmailVerification {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([token])
}

// ─────────────────────────────────────────────────────────────────────────────
// PRODUCTS & VARIANTS
// ─────────────────────────────────────────────────────────────────────────────

model Category {
  id         String   @id @default(cuid())
  businessId String
  name       String
  slug       String
  parentId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  parent     Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children   Category[] @relation("CategoryTree")
  products   Product[]

  @@unique([businessId, slug])
  @@index([businessId])
}

model Product {
  id          String   @id @default(cuid())
  businessId  String
  categoryId  String?
  name        String
  description String?
  basePrice   Decimal  @db.Decimal(12, 2)
  images      String[] // Cloudinary URLs
  barcode     String?
  isActive    Boolean  @default(true)
  hasVariants Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business      Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category      Category?      @relation(fields: [categoryId], references: [id])
  variantGroups VariantGroup[]
  variants      Variant[]
  orderLines    OrderLine[]    // for simple (no variant) products

  @@index([businessId])
  @@index([businessId, categoryId])
  @@index([businessId, isActive])
}

model VariantGroup {
  id           String   @id @default(cuid())
  productId    String
  name         String   // e.g. "Colour", "Size", "Material"
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())

  product      Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  optionValues OptionValue[]

  @@index([productId])
}

model OptionValue {
  id             String   @id @default(cuid())
  variantGroupId String
  value          String   // e.g. "Red", "Large", "Cotton"
  displayOrder   Int      @default(0)
  createdAt      DateTime @default(now())

  variantGroup   VariantGroup    @relation(fields: [variantGroupId], references: [id], onDelete: Cascade)
  variantOptions VariantOption[] // junction

  @@index([variantGroupId])
}

model Variant {
  id             String   @id @default(cuid())
  productId      String
  sku            String?
  price          Decimal  @db.Decimal(12, 2)
  stockQuantity  Int      @default(0)
  alertThreshold Int      @default(5)
  images         String[] // Cloudinary URLs — overrides product images
  barcode        String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantOptions VariantOption[] // junction to OptionValues
  orderLines     OrderLine[]
  adjustments    InventoryAdjustment[]

  @@index([productId])
  @@index([sku])
}

// Junction table: Variant ↔ OptionValue (many-to-many)
model VariantOption {
  variantId     String
  optionValueId String

  variant       Variant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  optionValue   OptionValue @relation(fields: [optionValueId], references: [id], onDelete: Cascade)

  @@id([variantId, optionValueId])
  @@index([variantId])
  @@index([optionValueId])
}

// ─────────────────────────────────────────────────────────────────────────────
// INVENTORY
// ─────────────────────────────────────────────────────────────────────────────

model Supplier {
  id         String   @id @default(cuid())
  businessId String
  name       String
  email      String?
  phone      String?
  address    String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business     Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  stockReceipts StockReceipt[]

  @@index([businessId])
}

model StockReceipt {
  id           String   @id @default(cuid())
  businessId   String
  supplierId   String?
  referenceNo  String?
  notes        String?
  receivedById String
  receivedAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  business     Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplier     Supplier?             @relation(fields: [supplierId], references: [id])
  items        StockReceiptItem[]

  @@index([businessId])
}

model StockReceiptItem {
  id             String   @id @default(cuid())
  stockReceiptId String
  variantId      String
  quantity       Int
  purchasePrice  Decimal  @db.Decimal(12, 2)

  stockReceipt   StockReceipt @relation(fields: [stockReceiptId], references: [id], onDelete: Cascade)

  @@index([stockReceiptId])
}

model InventoryAdjustment {
  id         String           @id @default(cuid())
  variantId  String
  userId     String
  delta      Int              // positive = add, negative = remove
  reason     AdjustmentReason
  notes      String?
  createdAt  DateTime         @default(now())

  variant    Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  user       User    @relation(fields: [userId], references: [id])

  @@index([variantId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// ORDERS & SALES
// ─────────────────────────────────────────────────────────────────────────────

model Order {
  id              String        @id @default(cuid())
  businessId      String
  cashierId       String
  status          OrderStatus   @default(OPEN)
  paymentMethod   PaymentMethod @default(CASH)
  subtotal        Decimal       @db.Decimal(12, 2)
  discountTotal   Decimal       @db.Decimal(12, 2) @default(0)
  taxAmount       Decimal       @db.Decimal(12, 2) @default(0)
  total           Decimal       @db.Decimal(12, 2)
  amountTendered  Decimal?      @db.Decimal(12, 2)
  changeDue       Decimal?      @db.Decimal(12, 2)
  mpesaRef        String?       // M-Pesa transaction reference
  receiptNo       String?       // human-readable receipt number
  notes           String?
  clientUuid      String?       @unique // idempotency key from offline sync
  deviceId        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  business        Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  cashier         User        @relation("CashierOrders", fields: [cashierId], references: [id])
  lines           OrderLine[]
  refunds         Refund[]

  @@index([businessId])
  @@index([businessId, status])
  @@index([businessId, createdAt])
  @@index([cashierId])
  @@index([clientUuid])
}

model OrderLine {
  id               String   @id @default(cuid())
  orderId          String
  productId        String?  // for simple products
  variantId        String?  // for variant products
  quantity         Int
  unitPriceAtSale  Decimal  @db.Decimal(12, 2)
  discount         Decimal  @db.Decimal(12, 2) @default(0)
  lineTotal        Decimal  @db.Decimal(12, 2)

  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product          Product? @relation(fields: [productId], references: [id])
  variant          Variant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([variantId])
}

model Refund {
  id          String   @id @default(cuid())
  orderId     String
  amount      Decimal  @db.Decimal(12, 2)
  reason      String?
  processedAt DateTime @default(now())

  order       Order    @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

// ─────────────────────────────────────────────────────────────────────────────
// BUSINESS SETTINGS
// ─────────────────────────────────────────────────────────────────────────────

model BusinessSettings {
  id                  String   @id @default(cuid())
  businessId          String   @unique
  taxRate             Decimal  @db.Decimal(5, 2) @default(16) // 16% VAT (Kenya)
  taxInclusive        Boolean  @default(false)
  receiptLogoUrl      String?
  receiptFooter       String?
  receiptPhone        String?
  enableCash          Boolean  @default(true)
  enableMpesa         Boolean  @default(true)
  enableCard          Boolean  @default(false)
  enableOther         Boolean  @default(false)
  lowStockEmailAlert  Boolean  @default(true)
  lowStockSmsAlert    Boolean  @default(false)
  autoPrintReceipt    Boolean  @default(true)
  minAppVersion       String?
  updatedAt           DateTime @updatedAt

  business            Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATIONS & AUDIT
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id         String           @id @default(cuid())
  businessId String
  type       NotificationType
  title      String
  body       String
  isRead     Boolean          @default(false)
  metadata   Json?
  createdAt  DateTime         @default(now())

  business   Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, isRead])
  @@index([businessId, createdAt])
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  action     String   // e.g. "product.create", "order.void", "login"
  entityType String?
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}
