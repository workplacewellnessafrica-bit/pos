# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/dukapos"

# ── API ───────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
API_BASE_URL=http://localhost:3001

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Africa's Talking ─────────────────────────────────────────────────────────
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=sandbox
AT_SENDER_ID=DUKAPOS

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Web Admin ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001/api/v1
VITE_WS_URL=http://localhost:3001

# ── Web Marketing ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@dukapos.com

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=DukaPOS
FRONTEND_URL=http://localhost:5173
